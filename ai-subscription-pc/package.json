{
  "name": "ai-subscription-pc",
  "version": "1.0.0",
  "description": "AI 订阅内容聚合 + 定时推送应用 - PC 端",
  "main": "main/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://127.0.0.1:5173 && electron .",
    "build": "npm run build:vite && npm run build:electron",
    "build:vite": "tsc && vite build",
    "build:electron": "electron-builder",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "antd": "^5.22.0",
    "@ant-design/icons": "^5.5.1",
    "dayjs": "^1.11.13",
    "electron-store": "^8.2.0",
    "node-cron": "^3.0.3",
    "rss-parser": "^3.13.0",
    "nodemailer": "^6.9.15",
    "uuid": "^10.0.0",
    "ai": "^3.4.0",
    "@ai-sdk/openai": "^0.0.70",
    "@ai-sdk/anthropic": "^0.0.62",
    "@ai-sdk/google": "^0.0.55",
    "zod": "^3.23.8",
    "mathjs": "^13.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/node": "^22.9.0",
    "@types/nodemailer": "^6.4.16",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.aisubscription.pc",
    "productName": "AI订阅助手",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "main/**/*",
      "preload/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
