{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "noEmit": false,
    "outDir": "dist-electron",
    "declaration": true,
    "declarationMap": true,
    "types": ["node"],
    "lib": ["ES2020"]
  },
  "include": ["vite.config.ts", "electron/**/*.ts"]
}
