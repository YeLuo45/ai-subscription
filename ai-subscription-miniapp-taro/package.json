{
  "name": "ai-subscription-miniapp-taro",
  "version": "1.0.0",
  "description": "AI 订阅内容聚合 + 定时推送 - 微信小程序端（Taro 4.x + React + TypeScript）",
  "scripts": {
    "build:weapp": "taro build --type weapp",
    "dev:weapp": "taro build --type weapp --watch",
    "build:h5": "taro build --type h5",
    "dev:h5": "taro build --type h5 --watch"
  },
  "browserslist": {
    "production": [
      "last 3 versions",
      "Android >= 4.1",
      "ios >= 8"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "dependencies": {
    "@tarojs/taro": "4.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@swc/core": "^1.10.1",
    "@tarojs/cli": "4.2.0",
    "@tarojs/helper": "4.2.0",
    "@tarojs/plugin-framework-react": "4.2.0",
    "@tarojs/plugin-platform-weapp": "4.2.0",
    "@tarojs/react": "4.2.0",
    "@tarojs/runtime": "4.2.0",
    "@tarojs/shared": "4.2.0",
    "@tarojs/webpack5-runner": "4.2.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "babel-preset-taro": "4.2.0",
    "typescript": "^5.3.0"
  }
}
